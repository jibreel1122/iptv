# Hostinger VPS production environment
# Copy this file to /opt/iptv_studo/.env on your VPS and fill values.

NODE_ENV=production
PORT=3000

# Supabase (recommended mode)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Optional: keep empty unless you use direct Postgres mode
# DATABASE_URL=postgresql://...

# Admin fallback credentials (only used when no DB and no Supabase)
# Keep these private and strong.
ADMIN_EMAIL=your-admin@email.com
# Option A: plain password (less recommended)
# ADMIN_PASSWORD=change_me
# Option B: sha256 hash (recommended)
ADMIN_PASSWORD_HASH=your_sha256_hash

# Strong secret for signed admin session tokens
ADMIN_JWT_SECRET=replace_with_long_random_secret
